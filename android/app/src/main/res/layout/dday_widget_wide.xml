<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_wide_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:paddingLeft="11dp"
    android:paddingTop="10dp"
    android:paddingRight="11dp"
    android:paddingBottom="10dp"
    android:background="@drawable/dday_widget_background">

    <LinearLayout
        android:id="@+id/widget_wide_row_1"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="90dp"
            android:layout_height="match_parent">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:alpha="0.10"
                android:src="@drawable/ic_widget_calendar_faint" />

            <TextView
                android:id="@+id/widget_wide_dday_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="D-Day"
                android:textColor="#7A3E91"
                android:textSize="29sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingLeft="10dp">

            <TextView
                android:id="@+id/widget_wide_title_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="결혼기념일"
                android:textColor="#111827"
                android:textSize="16.5sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/widget_wide_progress_1"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="7dp"
                android:max="100"
                android:progress="70"
                android:progressDrawable="@drawable/dday_widget_progress" />

            <TextView
                android:id="@+id/widget_wide_remain_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="오늘 · 2시간 남음"
                android:textColor="#6B7280"
                android:textSize="12.5sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_wide_message_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="조금만 더 기다려요 💜"
                android:textColor="#9A7BA8"
                android:textSize="11.5sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_wide_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:alpha="0.26"
        android:background="#AEB6C4"
        android:text="" />

    <LinearLayout
        android:id="@+id/widget_wide_row_2"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="90dp"
            android:layout_height="match_parent">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:alpha="0.10"
                android:src="@drawable/ic_widget_calendar_faint" />

            <TextView
                android:id="@+id/widget_wide_dday_2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="D-36"
                android:textColor="#F59E0B"
                android:textSize="29sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingLeft="10dp">

            <TextView
                android:id="@+id/widget_wide_title_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="여행 출발"
                android:textColor="#111827"
                android:textSize="16.5sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/widget_wide_progress_2"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="7dp"
                android:max="100"
                android:progress="20"
                android:progressDrawable="@drawable/dday_widget_progress" />

            <TextView
                android:id="@+id/widget_wide_remain_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="7일 남음"
                android:textColor="#6B7280"
                android:textSize="12.5sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_wide_message_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="천천히 준비해요 🌿"
                android:textColor="#9A7BA8"
                android:textSize="11.5sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
